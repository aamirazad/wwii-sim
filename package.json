{
	"name": "wwii-sim",
	"devDependencies": {
		"@biomejs/biome": "2.3.13",
		"turbo": "^2.8.0"
	},
	"catalog": {
		"@biomejs/biome": "2.3.13",
		"typescript": "5.9.3",
		"@elysiajs/eden": "^1.4.5",
		"@types/node": "^25.1.0"
	},
	"packageManager": "bun@1.3.0",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"api:build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server apps/api/src/index.ts",
		"dev": "turbo run dev",
		"lint": "biome check",
		"check-types": "turbo run check-types"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	]
}
